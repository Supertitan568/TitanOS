#include <resource_handling.h>
#include <scheduler.h>
#include <libtitan.h>
#include <vfs.h>
#include <vmm.h>

#define MAX_HANDLES 100

static size_t read_resource(resource_t* resource, void* buf, size_t len){
  switch(resource->type){
    case FILE:
      return vfs_read(resource->internal_handle, buf, len);
    default:
      ERROR("resource handling", "unimplemented resource type");
  }

  return 0;
}

resource_t* get_resource(process_t* process, int handle){
  if (handle < 0 || handle >= MAX_HANDLES){
    return NULL;
  }

  return process->resource_table[handle];
}


bool remove_resource(process_t* process, int handle){
  resource_t* resource = get_resource(process, handle);

  if(!resource || !resource->close){
    return false;
  }
  //resource->close(resource);
  process->resource_table[handle] = 0;
  return true;
}


int register_resource(process_t* process, resource_t* resource){
  if(!resource || !process || !resource->open){
    return -1;
  }
   
  // We open the resource and find the first open handle
  //resource->open(resource);
  for(int handle=0; handle<MAX_RESOURCES; handle++){
    if(process->resource_table[handle] == 0){
      process->resource_table[handle] = (resource_t*) kmalloc(sizeof(resource_t));
      *process->resource_table[handle] = *resource;
      return handle;
    }
  }
  
  //resource->close(resource);
  return -1;
}


int register_file_resource(const char* filename){
  resource_t resource = {
    .type = FILE,
    .internal_handle = vfs_open(filename, 0),
    .read = read_resource,
    .write = NULL,
    .open = NULL,
    .close = NULL
  };
  // This returns the process handle
  return register_resource(current_process, &resource);
}
